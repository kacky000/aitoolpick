---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, heroImage, tags = [] } = Astro.props;

const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  dateModified: pubDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'AIToolPick',
    url: 'https://aitoolpick.vercel.app',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AIToolPick',
    url: 'https://aitoolpick.vercel.app',
  },
  image: heroImage ? new URL(heroImage, 'https://aitoolpick.vercel.app').toString() : undefined,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(Astro.url.pathname, 'https://aitoolpick.vercel.app').toString(),
  },
});

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | AIToolPick Blog`} description={description} image={heroImage} type="article">
  <script type="application/ld+json" set:html={articleJsonLd} />
  <article class="article">
    <header class="article-header">
      <p class="article-date">{formattedDate}</p>
      <h1>{title}</h1>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="card-tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {heroImage && (
      <img class="article-hero" src={heroImage} alt={title} />
    )}

    <div class="article-content">
      <slot />
    </div>

    <div class="cta-section" style="margin-top: 3rem;">
      <h2>Find the Best Tool for You</h2>
      <p>Compare features, pricing, and reviews to find the perfect tool for your workflow.</p>
      <a href="/compare/notion-vs-clickup/" class="btn-primary">Find the best tool for you &rarr;</a>
    </div>
  </article>
</BaseLayout>
