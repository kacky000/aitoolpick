---
import '../styles/global.css';
import Newsletter from '../components/Newsletter.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
}

const { title, description, image = '/og-default.png', type = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AIToolPick',
  url: 'https://aitoolpick.org',
  description: 'Find and compare the best AI and productivity tools for your workflow.',
});
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="C_ki-T4Q9TpMGoUx_c2Yn8pNNd_ZxePU7YbJlUyeS90" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:site_name" content="AIToolPick" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  <!-- GA4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-C4Q09JKCBL"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-C4Q09JKCBL');
  </script>

  <!-- AdSense -->
  <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4052959814764437" crossorigin="anonymous"></script>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={jsonLd} />

  <!-- Styles -->
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">AI<span>ToolPick</span></a>
      <button class="nav-toggle" aria-label="Toggle menu" id="nav-toggle">&#9776;</button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/compare/">Compare</a></li>
        <li><a href="/rankings/">Rankings</a></li>
        <li><a href="/free/">Free Tools</a></li>
        <li><a href="/quiz/">Find My Tool</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/submit/">Submit</a></li>
      </ul>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <span id="theme-icon">&#9728;&#65039;</span>
      </button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <Newsletter />

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <h3>AI<span>ToolPick</span></h3>
        <p>Helping you find the perfect tools for your workflow. Honest comparisons, no fluff.</p>
        <div class="footer-social">
          <a href="https://x.com/AIToolPick" target="_blank" rel="noopener noreferrer" aria-label="Follow us on X (Twitter)">&#120143;</a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Compare</h4>
        <ul>
          <li><a href="/compare/">All Comparisons</a></li>
          <li><a href="/compare/notion-vs-clickup/">Notion vs ClickUp</a></li>
          <li><a href="/compare/chatgpt-vs-claude/">ChatGPT vs Claude</a></li>
          <li><a href="/compare/canva-vs-figma/">Canva vs Figma</a></li>
          <li><a href="/compare/asana-vs-monday/">Asana vs Monday</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Alternatives</h4>
        <ul>
          <li><a href="/alternatives/notion/">Notion Alternatives</a></li>
          <li><a href="/alternatives/chatgpt/">ChatGPT Alternatives</a></li>
          <li><a href="/alternatives/slack/">Slack Alternatives</a></li>
          <li><a href="/alternatives/canva/">Canva Alternatives</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} AIToolPick. All rights reserved.</p>
    </div>
  </footer>

  <script is:inline>
    // Theme toggle
    (function() {
      const savedTheme = localStorage.getItem('aitoolpick-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = savedTheme || (prefersDark ? 'dark' : 'light');
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
      function updateIcon() {
        const icon = document.getElementById('theme-icon');
        if (icon) {
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          icon.innerHTML = isDark ? '&#9728;&#65039;' : '&#127769;';
        }
      }
      document.addEventListener('DOMContentLoaded', function() {
        updateIcon();
        document.getElementById('theme-toggle')?.addEventListener('click', function() {
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          if (isDark) {
            document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('aitoolpick-theme', 'light');
          } else {
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('aitoolpick-theme', 'dark');
          }
          updateIcon();
        });
        document.getElementById('nav-toggle')?.addEventListener('click', function() {
          document.getElementById('nav-links')?.classList.toggle('open');
        });
      });
    })();
  </script>
</body>
</html>
