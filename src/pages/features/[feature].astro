---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import tools from '../../data/tools.json';

export function getStaticPaths() {
  // Collect all features with 3+ tools
  const featureMap = new Map<string, typeof tools>();

  for (const tool of tools) {
    for (const feature of tool.features) {
      if (!featureMap.has(feature)) featureMap.set(feature, []);
      featureMap.get(feature)!.push(tool);
    }
  }

  return Array.from(featureMap.entries())
    .filter(([, toolList]) => toolList.length >= 3)
    .map(([feature, toolList]) => ({
      params: { feature },
      props: {
        feature,
        matchedTools: toolList.sort((a, b) => b.rating - a.rating),
      },
    }));
}

const { feature, matchedTools } = Astro.props;

function formatFeature(slug: string): string {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase());
}

function formatPrice(pricing: Record<string, number | boolean | null>): string {
  const entries = Object.entries(pricing).filter(([key, val]) => key !== 'free' && val !== null && typeof val === 'number');
  if (entries.length === 0) return pricing.free ? 'Free' : 'Contact sales';
  const lowest = Math.min(...entries.map(([, v]) => v as number));
  return pricing.free ? `Free / $${lowest}+` : `$${lowest}+`;
}

const featureFormatted = formatFeature(feature);
const freeCount = matchedTools.filter((t) => t.pricing.free).length;

const pageTitle = `Best Tools with ${featureFormatted} — ${matchedTools.length} Options Compared`;
const pageDescription = `Compare ${matchedTools.length} tools that offer ${featureFormatted.toLowerCase()}. Find the best option with pricing, ratings, and feature comparisons.`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Tools with ${featureFormatted}`,
  description: pageDescription,
  numberOfItems: matchedTools.length,
  itemListElement: matchedTools.slice(0, 10).map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://aitoolpick.org/tools/${tool.slug}/`,
    },
  })),
});
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={jsonLd} />

  <section class="section">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Features', href: '/features/' },
        { label: featureFormatted },
      ]} />

      <div class="feat-header">
        <h1>Tools with {featureFormatted}</h1>
        <p>{matchedTools.length} tools offer {featureFormatted.toLowerCase()}. {freeCount > 0 ? `${freeCount} have free plans.` : ''}</p>
      </div>

      <!-- Quick comparison table -->
      <div class="feat-table-wrap">
        <table class="feat-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Tool</th>
              <th>Rating</th>
              <th>Free Plan</th>
              <th>Price</th>
            </tr>
          </thead>
          <tbody>
            {matchedTools.slice(0, 15).map((tool, i) => (
              <tr>
                <td class="feat-rank">{i + 1}</td>
                <td><a href={`/tools/${tool.slug}/`}>{tool.name}</a></td>
                <td class="feat-rating">★ {tool.rating}</td>
                <td class={tool.pricing.free ? 'feat-yes' : 'feat-no'}>{tool.pricing.free ? '✓' : '✗'}</td>
                <td>{formatPrice(tool.pricing)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Tool Cards -->
      <div class="feat-grid">
        {matchedTools.map((tool, i) => (
          <a href={`/tools/${tool.slug}/`} class="feat-card">
            <div class="feat-card-top">
              <span class="feat-card-rank">#{i + 1}</span>
              {tool.icon && <img src={tool.icon} alt={tool.name} width="32" height="32" style="border-radius: 8px;" loading="lazy" />}
              <div>
                <h2>{tool.name}</h2>
                <span class="feat-card-rating">★ {tool.rating}</span>
              </div>
            </div>
            <p>{tool.description.slice(0, 100)}{tool.description.length > 100 ? '...' : ''}</p>
            <div class="feat-card-meta">
              <span class="feat-card-price">{formatPrice(tool.pricing)}</span>
              {tool.pricing.free && <span class="feat-card-free">Free</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .feat-header {
    margin-bottom: 2rem;
  }

  .feat-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .feat-header p {
    color: var(--gray-600);
    font-size: 1rem;
  }

  .feat-table-wrap {
    overflow-x: auto;
    margin-bottom: 2.5rem;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
  }

  .feat-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .feat-table th {
    background: var(--gray-50);
    padding: 0.7rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--gray-600);
    border-bottom: 1px solid var(--gray-200);
  }

  .feat-table td {
    padding: 0.6rem 0.7rem;
    border-bottom: 1px solid var(--gray-100);
  }

  .feat-table a {
    font-weight: 600;
    color: var(--dark);
    text-decoration: none;
  }

  .feat-table a:hover {
    color: var(--primary-dark);
  }

  .feat-rank { font-weight: 700; color: var(--primary-dark); width: 35px; }
  .feat-rating { color: var(--warning); font-weight: 600; }
  .feat-yes { color: var(--success); font-weight: 600; }
  .feat-no { color: var(--gray-400); }

  .feat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .feat-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.2s;
  }

  .feat-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .feat-card-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .feat-card-rank {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--primary-dark);
  }

  .feat-card-top h2 {
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0;
  }

  .feat-card-rating {
    font-size: 0.72rem;
    color: var(--warning);
    font-weight: 600;
    margin-left: auto;
  }

  .feat-card p {
    font-size: 0.8rem;
    color: var(--gray-600);
    line-height: 1.4;
    margin: 0;
  }

  .feat-card-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: auto;
  }

  .feat-card-price {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--primary-dark);
  }

  .feat-card-free {
    font-size: 0.68rem;
    padding: 0.1rem 0.4rem;
    background: var(--success-light, #d1fae5);
    color: var(--success, #059669);
    border-radius: 8px;
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .feat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
