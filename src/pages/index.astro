---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import tools from '../data/tools.json';
import categories from '../data/categories.json';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = allPosts.slice(0, 6);

const popularComparisons = [
  { slugA: 'chatgpt', slugB: 'claude', nameA: 'ChatGPT', nameB: 'Claude' },
  { slugA: 'cursor', slugB: 'github-copilot', nameA: 'Cursor', nameB: 'GitHub Copilot' },
  { slugA: 'notion', slugB: 'clickup', nameA: 'Notion', nameB: 'ClickUp' },
  { slugA: 'midjourney', slugB: 'dall-e', nameA: 'Midjourney', nameB: 'DALL-E 3' },
  { slugA: 'canva', slugB: 'figma', nameA: 'Canva', nameB: 'Figma' },
  { slugA: 'vercel', slugB: 'netlify', nameA: 'Vercel', nameB: 'Netlify' },
  { slugA: 'zapier', slugB: 'make', nameA: 'Zapier', nameB: 'Make' },
  { slugA: 'ahrefs', slugB: 'semrush', nameA: 'Ahrefs', nameB: 'Semrush' },
];
---

<BaseLayout
  title="AIToolPick — Find the Perfect Tool for Your Workflow"
  description="Compare AI and productivity tools side-by-side. Honest reviews, pricing breakdowns, and feature comparisons to help you pick the right tool."
>
  <!-- Hero -->
  <section class="hero">
    <h1>Find the <span class="highlight">Perfect Tool</span> for Your Workflow</h1>
    <p>Compare features, pricing, and reviews across {tools.length}+ top productivity and AI tools.</p>
    <div class="hero-search">
      <input type="text" placeholder="Search tools... (e.g., Notion, ChatGPT)" id="hero-search-input" />
      <span class="hero-search-icon">&#128269;</span>
    </div>
    <div id="search-results" class="search-results" style="display:none;"></div>
  </section>

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Browse by Category</h2>
      <p class="section-subtitle">Find tools organized by what you need to get done.</p>
      <div class="category-grid">
        {categories.filter(cat => tools.some(t => t.category.includes(cat.id))).slice(0, 20).map((cat) => {
          const count = tools.filter(t => t.category.includes(cat.id)).length;
          return (
            <a href={`/category/${cat.slug}/`} class="category-card">
              <span class="icon">{cat.icon}</span>
              <span class="label">{cat.name} ({count})</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Top Rated Tools -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Top Rated Tools</h2>
      <p class="section-subtitle">The highest-rated tools across all categories.</p>
      <div class="top-tools-grid">
        {tools.sort((a, b) => b.rating - a.rating).slice(0, 8).map((tool, i) => (
          <a href={`/tools/${tool.slug}/`} class="top-tool-card">
            <span class="top-tool-rank">#{i + 1}</span>
            {tool.icon && <img src={tool.icon} alt={tool.name} width="32" height="32" style="border-radius: 8px;" />}
            <div class="top-tool-info">
              <strong>{tool.name}</strong>
              <span>{'★'.repeat(Math.round(tool.rating))} {tool.rating}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Best For Role -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Find Tools for Your Role</h2>
      <p class="section-subtitle">Curated tool recommendations based on what you do.</p>
      <div class="role-grid">
        <a href="/best-for/developers/" class="role-card"><span class="role-icon">👨‍💻</span><span>Developers</span></a>
        <a href="/best-for/designers/" class="role-card"><span class="role-icon">🎨</span><span>Designers</span></a>
        <a href="/best-for/marketers/" class="role-card"><span class="role-icon">📈</span><span>Marketers</span></a>
        <a href="/best-for/freelancers/" class="role-card"><span class="role-icon">💼</span><span>Freelancers</span></a>
        <a href="/best-for/startups/" class="role-card"><span class="role-icon">🚀</span><span>Startups</span></a>
        <a href="/best-for/students/" class="role-card"><span class="role-icon">🎓</span><span>Students</span></a>
        <a href="/best-for/content-creators/" class="role-card"><span class="role-icon">✏️</span><span>Creators</span></a>
        <a href="/best-for/remote-teams/" class="role-card"><span class="role-icon">🌍</span><span>Remote Teams</span></a>
        <a href="/best-for/solopreneurs/" class="role-card"><span class="role-icon">🧑‍💻</span><span>Solopreneurs</span></a>
        <a href="/best-for/product-managers/" class="role-card"><span class="role-icon">📋</span><span>PMs</span></a>
      </div>
    </div>
  </section>

  <!-- Popular Comparisons -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Popular Comparisons</h2>
      <p class="section-subtitle">See how the top tools stack up against each other.</p>
      <div class="comparison-links">
        {popularComparisons.map((comp) => (
          <a href={`/compare/${comp.slugA}-vs-${comp.slugB}/`} class="comparison-link">
            <span>{comp.nameA} vs {comp.nameB}</span>
            <span class="arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  {latestPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Latest Articles</h2>
        <p class="section-subtitle">Tips, guides, and insights on the best tools.</p>
        <div class="post-grid">
          {latestPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="post-card" style="text-decoration: none; color: inherit;">
              {post.data.heroImage ? (
                <img class="post-card-image" src={post.data.heroImage} alt={post.data.title} loading="lazy" />
              ) : (
                <div class="post-card-image post-card-image--placeholder">
                  <span>{post.data.title.slice(0, 1)}</span>
                </div>
              )}
              <div class="post-card-body">
                <p class="post-card-date">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </p>
                <h3 class="post-card-title">{post.data.title}</h3>
                <p class="post-card-excerpt">{post.data.description}</p>
                {post.data.tags && (
                  <div class="post-card-tags">
                    {post.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="card-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Quick Links -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Explore More</h2>
      <div class="explore-grid">
        <a href="/trending/" class="explore-card">
          <span class="explore-icon">🔥</span>
          <strong>Trending Tools</strong>
          <span>New tools gaining traction</span>
        </a>
        <a href="/open-source/" class="explore-card">
          <span class="explore-icon">🔓</span>
          <strong>Open Source</strong>
          <span>Self-host & own your data</span>
        </a>
        <a href="/new/" class="explore-card">
          <span class="explore-icon">✨</span>
          <strong>New Tools</strong>
          <span>Recently launched</span>
        </a>
        <a href="/workflow/" class="explore-card">
          <span class="explore-icon">⚙️</span>
          <strong>Workflows</strong>
          <span>Build your perfect stack</span>
        </a>
        <a href="/pricing-compare/" class="explore-card">
          <span class="explore-icon">💰</span>
          <strong>Pricing</strong>
          <span>Compare costs side by side</span>
        </a>
        <a href="/stacks/" class="explore-card">
          <span class="explore-icon">🧱</span>
          <strong>Tool Stacks</strong>
          <span>Curated combinations</span>
        </a>
        <a href="/rankings/" class="explore-card">
          <span class="explore-icon">🏆</span>
          <strong>Rankings</strong>
          <span>Top 100 overall</span>
        </a>
        <a href="/free/" class="explore-card">
          <span class="explore-icon">🆓</span>
          <strong>Free Tools</strong>
          <span>No credit card needed</span>
        </a>
        <a href="/features/" class="explore-card">
          <span class="explore-icon">🔍</span>
          <strong>By Feature</strong>
          <span>Find tools by capability</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Ready to Find Your Perfect Tool?</h2>
        <p>Compare features, pricing, and reviews side by side to make the right choice.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="/tools/" class="btn-primary">Browse All {tools.length} Tools &rarr;</a>
          <a href="/compare/" class="btn-secondary">Start Comparing &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ tools }}>
    const searchInput = document.getElementById('hero-search-input');
    const searchResults = document.getElementById('search-results');
    const toolData = tools;

    searchInput.addEventListener('input', (e) => {
      const q = e.target.value.trim().toLowerCase();
      if (q.length < 2) {
        searchResults.style.display = 'none';
        return;
      }
      const matches = toolData.filter(t =>
        t.name.toLowerCase().includes(q) ||
        t.description.toLowerCase().includes(q) ||
        t.category.some(c => c.toLowerCase().includes(q))
      ).slice(0, 6);

      if (matches.length === 0) {
        searchResults.innerHTML = '<div class="search-empty">No tools found</div>';
      } else {
        searchResults.innerHTML = matches.map(t =>
          `<a href="/tools/${t.slug}/" class="search-item">
            <img src="${t.icon}" alt="${t.name}" width="24" height="24" />
            <div>
              <strong>${t.name}</strong>
              <span>${t.description}</span>
            </div>
          </a>`
        ).join('');
      }
      searchResults.style.display = 'block';
    });

    document.addEventListener('click', (e) => {
      if (!searchResults.contains(e.target) && e.target !== searchInput) {
        searchResults.style.display = 'none';
      }
    });
  </script>

  <style>
    .search-results {
      max-width: 500px;
      margin: 0.5rem auto 0;
      background: var(--white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      text-align: left;
    }
    .search-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      color: var(--dark);
      text-decoration: none;
      border-bottom: 1px solid var(--gray-100);
      transition: background 0.15s;
    }
    .search-item:hover {
      background: var(--gray-50);
    }
    .search-item img {
      border-radius: 6px;
      flex-shrink: 0;
    }
    .search-item strong {
      display: block;
      font-size: 0.95rem;
    }
    .search-item span {
      font-size: 0.8rem;
      color: var(--gray-500);
      display: block;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 350px;
    }
    .search-empty {
      padding: 1rem;
      color: var(--gray-500);
      text-align: center;
      font-size: 0.9rem;
    }

    /* Top Tools */
    .top-tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 0.75rem;
    }

    .top-tool-card {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.85rem 1rem;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      text-decoration: none;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
    }

    .top-tool-card:hover {
      border-color: var(--primary);
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
    }

    .top-tool-rank {
      font-size: 0.8rem;
      font-weight: 800;
      color: var(--primary-dark);
      min-width: 28px;
    }

    .top-tool-info {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .top-tool-info strong {
      font-size: 0.92rem;
      color: var(--dark);
    }

    .top-tool-info span {
      font-size: 0.78rem;
      color: var(--warning);
    }

    /* Role Grid */
    .role-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.75rem;
    }

    .role-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      padding: 1.25rem 0.75rem;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      text-decoration: none;
      color: var(--dark);
      font-size: 0.88rem;
      font-weight: 600;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
    }

    .role-card:hover {
      border-color: var(--primary);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .role-icon {
      font-size: 1.75rem;
    }

    .explore-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
    }

    .explore-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      padding: 1.25rem 1rem;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      text-decoration: none;
      color: inherit;
      text-align: center;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
    }

    .explore-card:hover {
      border-color: var(--primary);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .explore-icon {
      font-size: 1.5rem;
    }

    .explore-card strong {
      font-size: 0.9rem;
    }

    .explore-card span:last-child {
      font-size: 0.75rem;
      color: var(--gray-500);
    }
  </style>
</BaseLayout>
