---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import tools from '../../data/tools.json';
import categories from '../../data/categories.json';

const categoriesWithTools = categories
  .filter((cat) => tools.filter((t) => t.category.includes(cat.id)).length >= 3)
  .map((cat) => ({
    ...cat,
    toolCount: tools.filter((t) => t.category.includes(cat.id)).length,
    topTool: tools.filter((t) => t.category.includes(cat.id)).sort((a, b) => b.rating - a.rating)[0],
  }))
  .sort((a, b) => b.toolCount - a.toolCount);
---

<BaseLayout
  title="Top Tools by Category — Best Software Rankings 2026 | AIToolPick"
  description={`Top-ranked tools across ${categoriesWithTools.length} categories. See the #1 tool in each category based on ratings and features.`}
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Top Tools' },
      ]} />

      <h1 style="margin-bottom: 0.5rem;">Top Tools by Category</h1>
      <p style="color: var(--gray-600); margin-bottom: 2.5rem;">
        {categoriesWithTools.length} categories ranked. See the best tools in each category for 2026.
      </p>

      <div class="cat-grid">
        {categoriesWithTools.map((cat) => (
          <a href={`/top/${cat.slug}/`} class="cat-card">
            <div class="cat-card-header">
              <span class="cat-icon">{cat.icon}</span>
              <div>
                <h2>{cat.name}</h2>
                <span class="cat-count">{cat.toolCount} tools</span>
              </div>
            </div>
            {cat.topTool && (
              <div class="cat-winner">
                <span class="winner-label">#1</span>
                <span class="winner-name">{cat.topTool.name}</span>
                <span class="winner-rating">★ {cat.topTool.rating}</span>
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.2s, transform 0.1s;
  }

  .cat-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  .cat-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cat-icon {
    font-size: 1.5rem;
  }

  .cat-card-header h2 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--dark);
    margin: 0;
  }

  .cat-count {
    font-size: 0.78rem;
    color: var(--gray-500);
  }

  .cat-winner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--gray-50);
    border-radius: var(--radius);
  }

  .winner-label {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--warning);
  }

  .winner-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--dark);
  }

  .winner-rating {
    font-size: 0.78rem;
    color: var(--warning);
    margin-left: auto;
  }
</style>
