---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';
import categories from '../../data/categories.json';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

// Filter tools belonging to this category
const categoryTools = tools.filter((t) => t.category.includes(category.id));

function formatPrice(pricing: Record<string, number | boolean | null>): string {
  const entries = Object.entries(pricing).filter(
    ([key, val]) => key !== 'free' && val !== null && typeof val === 'number'
  );
  if (entries.length === 0) return pricing.free ? 'Free' : 'Contact sales';
  const lowest = Math.min(...entries.map(([, v]) => v as number));
  return pricing.free ? `Free / $${lowest}+` : `$${lowest}+`;
}

const pageTitle = `Best ${category.name} Tools in 2026 — Compare & Choose`;
const pageDescription = `Compare the ${categoryTools.length} best ${category.name.toLowerCase()} tools in 2026. Find pricing, features, pros & cons to pick the right one.`;

// Sort by rating for display
const sortedTools = [...categoryTools].sort((a, b) => b.rating - a.rating);
const topTool = sortedTools[0];
const freeTools = categoryTools.filter((t) => t.pricing.free);
const avgRating = categoryTools.length > 0
  ? (categoryTools.reduce((s, t) => s + t.rating, 0) / categoryTools.length).toFixed(1)
  : '0';

// Generate FAQ
const faqs = [
  {
    q: `What is the best ${category.name.toLowerCase()} tool in 2026?`,
    a: topTool ? `Based on our ratings, ${topTool.name} (${topTool.rating}/5) is the top-rated ${category.name.toLowerCase()} tool in 2026. It stands out for ${topTool.pros[0].toLowerCase()} and ${topTool.pros[1].toLowerCase()}.` : `We're still evaluating the best ${category.name.toLowerCase()} tools.`,
  },
  {
    q: `Are there free ${category.name.toLowerCase()} tools?`,
    a: freeTools.length > 0
      ? `Yes! ${freeTools.length} out of ${categoryTools.length} ${category.name.toLowerCase()} tools offer free plans, including ${freeTools.slice(0, 3).map((t) => t.name).join(', ')}.`
      : `Currently, most ${category.name.toLowerCase()} tools require a paid subscription. Check individual tool pages for trial options.`,
  },
  {
    q: `How do I choose the right ${category.name.toLowerCase()} tool?`,
    a: `Consider your team size, budget, and key features you need. Our comparison pages and quiz can help narrow down the best fit. Key factors include pricing (free vs paid), integrations, and ease of use.`,
  },
  {
    q: `How many ${category.name.toLowerCase()} tools does AIToolPick compare?`,
    a: `We currently compare ${categoryTools.length} ${category.name.toLowerCase()} tools with detailed reviews, pricing breakdowns, and head-to-head comparisons.`,
  },
];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Best ${category.name} Tools`,
  description: pageDescription,
  numberOfItems: categoryTools.length,
  itemListElement: sortedTools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: tool.name,
    url: `https://aitoolpick.org/tools/${tool.slug}/`,
  })),
});

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
});
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  <script type="application/ld+json" set:html={faqJsonLd} slot="head" />

  <!-- Breadcrumb -->
  <nav class="breadcrumb" style="max-width: var(--max-width); padding-top: 1.5rem;">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href="/#categories">Categories</a></li>
      <li>{category.name}</li>
    </ol>
  </nav>

  <!-- Header -->
  <div class="category-header">
    <span class="category-header-icon">{category.icon}</span>
    <h1>Best {category.name} Tools</h1>
    <p class="category-header-subtitle">
      Compare {categoryTools.length} top {category.name.toLowerCase()} tools. Find the perfect solution for your workflow.
    </p>
  </div>

  <!-- Tools Grid -->
  <section class="section">
    <div class="container">
      <div class="category-tools-grid">
        {categoryTools.map((tool) => {
          const compareSlug = categoryTools.length > 1
            ? [tool.slug, categoryTools.find((t) => t.id !== tool.id)?.slug].filter(Boolean).sort().join('-vs-')
            : '';
          return (
            <div class="card category-tool-card">
              <div class="card-header">
                {tool.icon && (
                  <img src={tool.icon} alt={`${tool.name} icon`} width="40" height="40" style="border-radius: 10px;" />
                )}
                <div>
                  <a href={`/tools/${tool.slug}/`} class="card-title-link">
                    <h3 class="card-title">{tool.name}</h3>
                  </a>
                  <div class="card-rating">
                    <span>{'★'.repeat(Math.round(tool.rating))}</span>
                    <span>{tool.rating}</span>
                  </div>
                </div>
              </div>

              <p class="card-description">{tool.description}</p>

              <div class="card-meta">
                <span class="card-price">{formatPrice(tool.pricing)}</span>
                {tool.pricing.free && <span class="card-tag">Free Plan</span>}
              </div>

              <div class="category-tool-actions">
                <a href={`/tools/${tool.slug}/`} class="btn-primary" style="font-size: 0.85rem; padding: 0.5rem 1.25rem;">
                  View Details
                </a>
                {compareSlug && (
                  <a href={`/compare/${compareSlug}/`} class="btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1.25rem;">
                    Compare
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>

      {categoryTools.length === 0 && (
        <div style="text-align: center; padding: 3rem; color: var(--gray-500);">
          <p>No tools found in this category yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <h2 style="margin-bottom: 1.5rem;">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Not sure which {category.name.toLowerCase()} tool to pick?</h2>
        <p>Take our quiz to find the best tool for your specific needs.</p>
        <a href="/quiz/" class="btn-primary">Find My Tool &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-header {
    text-align: center;
    padding: 2.5rem 1.5rem 1.5rem;
  }

  .category-header-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .category-header h1 {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .category-header-subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .category-tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .category-tool-card {
    display: flex;
    flex-direction: column;
  }

  .category-tool-card .card-description {
    flex: 1;
  }

  .card-title-link {
    text-decoration: none;
    color: inherit;
  }

  .card-title-link:hover .card-title {
    color: var(--primary);
  }

  .category-tool-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1rem 1.25rem;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.95rem;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--gray-400);
    font-weight: 300;
  }

  .faq-item[open] summary::after {
    content: '-';
  }

  .faq-item p {
    padding: 0 1.25rem 1rem;
    font-size: 0.9rem;
    color: var(--gray-600);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .category-tools-grid {
      grid-template-columns: 1fr;
    }

    .category-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
