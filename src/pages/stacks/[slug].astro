---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import stacks from '../../data/stacks.json';
import tools from '../../data/tools.json';

export function getStaticPaths() {
  return stacks.map((stack) => ({
    params: { slug: stack.slug },
    props: { stack },
  }));
}

const { stack } = Astro.props;

// Match tools from the stack
const stackTools = stack.tools
  .map((slug: string) => tools.find((t) => t.slug === slug))
  .filter(Boolean);

function formatPrice(pricing: Record<string, number | boolean | null>): string {
  const entries = Object.entries(pricing).filter(([key, val]) => key !== 'free' && val !== null && typeof val === 'number');
  if (entries.length === 0) return pricing.free ? 'Free' : 'Contact sales';
  const lowest = Math.min(...entries.map(([, v]) => v as number));
  return pricing.free ? `Free / $${lowest}+` : `$${lowest}+`;
}

// Calculate total monthly cost (lowest plans)
const monthlyTotal = stackTools.reduce((sum: number, t: any) => {
  if (t.pricing.free) return sum;
  const prices = Object.entries(t.pricing)
    .filter(([k, v]) => k !== 'free' && typeof v === 'number')
    .map(([, v]) => v as number);
  return sum + (prices.length > 0 ? Math.min(...prices) : 0);
}, 0);

const freeCount = stackTools.filter((t: any) => t.pricing.free).length;

const pageTitle = `${stack.title} — Best Tool Combination for 2026 | AIToolPick`;
const pageDescription = `${stack.description} ${stackTools.length} tools reviewed with pricing breakdown.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section">
    <div class="container stack-page">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Tool Stacks', href: '/stacks/' },
        { label: stack.title },
      ]} />

      <div class="stack-header">
        <h1>{stack.title}</h1>
        <p>{stack.description}</p>
        <div class="stack-stats">
          <div class="stat">
            <strong>{stackTools.length}</strong>
            <span>Tools</span>
          </div>
          <div class="stat">
            <strong>{freeCount}</strong>
            <span>Free Plans</span>
          </div>
          <div class="stat">
            <strong>${monthlyTotal > 0 ? `~${monthlyTotal}` : '0'}/mo</strong>
            <span>Min. Cost</span>
          </div>
        </div>
      </div>

      <!-- Category breakdown -->
      <div class="stack-categories">
        {stack.categories.map((cat: string) => (
          <span class="stack-cat-badge">{cat}</span>
        ))}
      </div>

      <!-- Tool cards -->
      <div class="stack-tools">
        {stackTools.map((tool: any, i: number) => (
          <div class="stack-tool-card">
            <div class="stack-tool-number">{i + 1}</div>
            <div class="stack-tool-main">
              <div class="stack-tool-header">
                {tool.icon && <img src={tool.icon} alt={tool.name} width="40" height="40" style="border-radius: 10px;" />}
                <div>
                  <h2><a href={`/tools/${tool.slug}/`}>{tool.name}</a></h2>
                  <span class="stack-tool-role">{stack.categories[i] || tool.category[0]?.replace(/-/g, ' ')}</span>
                </div>
                <span class="stack-tool-price">{formatPrice(tool.pricing)}</span>
              </div>
              <p class="stack-tool-desc">{tool.description}</p>
              <div class="stack-tool-features">
                {tool.features.slice(0, 3).map((f: string) => (
                  <span class="feature-tag">{f}</span>
                ))}
              </div>
              <div class="stack-tool-actions">
                <a href={`/tools/${tool.slug}/`} class="btn-link">Full Review →</a>
                <a href={tool.website} target="_blank" rel="noopener noreferrer" class="btn-link">Visit Site →</a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Total cost summary -->
      <div class="stack-summary">
        <h2>Stack Cost Summary</h2>
        <table class="cost-table">
          <thead>
            <tr>
              <th>Tool</th>
              <th>Free Plan</th>
              <th>Starting Price</th>
            </tr>
          </thead>
          <tbody>
            {stackTools.map((tool: any) => (
              <tr>
                <td><strong>{tool.name}</strong></td>
                <td>{tool.pricing.free ? '✓' : '✗'}</td>
                <td>{formatPrice(tool.pricing)}</td>
              </tr>
            ))}
          </tbody>
        </table>
        {monthlyTotal > 0 && (
          <p class="cost-note">Minimum monthly cost (paid plans): ~${monthlyTotal}/mo. Use free plans where available to reduce costs.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .stack-page {
    max-width: 860px;
  }

  .stack-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .stack-header > p {
    color: var(--gray-600);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .stack-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat strong {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--primary-dark);
  }

  .stat span {
    font-size: 0.78rem;
    color: var(--gray-500);
  }

  .stack-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
  }

  .stack-cat-badge {
    font-size: 0.8rem;
    padding: 0.3rem 0.7rem;
    background: var(--accent-light);
    color: var(--accent-dark);
    border-radius: 15px;
    font-weight: 500;
  }

  .stack-tools {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .stack-tool-card {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    transition: box-shadow 0.2s;
  }

  .stack-tool-card:hover {
    box-shadow: var(--shadow-md);
  }

  .stack-tool-number {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-100);
    color: var(--gray-600);
    font-weight: 700;
    font-size: 0.8rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .stack-tool-main {
    flex: 1;
    min-width: 0;
  }

  .stack-tool-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }

  .stack-tool-header h2 {
    font-size: 1.05rem;
    margin: 0;
  }

  .stack-tool-header h2 a {
    color: var(--dark);
    text-decoration: none;
  }

  .stack-tool-header h2 a:hover {
    color: var(--primary-dark);
  }

  .stack-tool-role {
    font-size: 0.75rem;
    color: var(--gray-500);
    text-transform: capitalize;
  }

  .stack-tool-price {
    margin-left: auto;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary-dark);
    background: var(--primary-light);
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
  }

  .stack-tool-desc {
    font-size: 0.88rem;
    color: var(--gray-600);
    line-height: 1.5;
    margin-bottom: 0.6rem;
  }

  .stack-tool-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.6rem;
  }

  .feature-tag {
    font-size: 0.72rem;
    padding: 0.2rem 0.5rem;
    background: var(--gray-100);
    color: var(--gray-600);
    border-radius: 10px;
  }

  .stack-tool-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-link {
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .btn-link:hover {
    text-decoration: underline;
  }

  .stack-summary {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    padding: 2rem;
  }

  .stack-summary h2 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .cost-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  .cost-table th, .cost-table td {
    padding: 0.6rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--gray-200);
    font-size: 0.88rem;
  }

  .cost-table th {
    font-weight: 600;
    color: var(--gray-600);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .cost-note {
    font-size: 0.82rem;
    color: var(--gray-600);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .stack-tool-card {
      flex-direction: column;
    }

    .stack-stats {
      gap: 1.5rem;
    }
  }
</style>
