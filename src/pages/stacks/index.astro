---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import stacks from '../../data/stacks.json';
import tools from '../../data/tools.json';

// Enrich stacks with tool data
const enrichedStacks = stacks.map((stack) => {
  const stackTools = stack.tools
    .map((slug: string) => tools.find((t) => t.slug === slug))
    .filter(Boolean);
  const freeCount = stackTools.filter((t: any) => t.pricing.free).length;
  return { ...stack, toolCount: stackTools.length, freeCount };
});
---

<BaseLayout
  title="Tool Stacks — Best Tool Combinations for Every Workflow | AIToolPick"
  description={`${stacks.length} curated tool stacks for startups, freelancers, developers, and more. Find the perfect combination of tools for your workflow.`}
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Tool Stacks' },
      ]} />

      <h1 style="margin-bottom: 0.5rem;">Tool Stacks</h1>
      <p style="color: var(--gray-600); margin-bottom: 2.5rem; font-size: 1.05rem;">
        Curated tool combinations for every role and workflow. See what the best teams use together.
      </p>

      <div class="stacks-grid">
        {enrichedStacks.map((stack) => (
          <a href={`/stacks/${stack.slug}/`} class="stack-card">
            <h2>{stack.title}</h2>
            <p>{stack.description}</p>
            <div class="stack-card-meta">
              <span>{stack.toolCount} tools</span>
              <span>{stack.freeCount} free</span>
              <span>{stack.categories.length} categories</span>
            </div>
            <div class="stack-card-categories">
              {stack.categories.slice(0, 4).map((cat: string) => (
                <span class="mini-badge">{cat}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .stacks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .stack-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.5rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.2s, transform 0.15s;
  }

  .stack-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .stack-card h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--dark);
    margin: 0;
  }

  .stack-card p {
    font-size: 0.88rem;
    color: var(--gray-600);
    line-height: 1.5;
    margin: 0;
  }

  .stack-card-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.78rem;
    color: var(--gray-500);
    font-weight: 500;
  }

  .stack-card-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: auto;
  }

  .mini-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: var(--gray-100);
    color: var(--gray-600);
    border-radius: 10px;
  }
</style>
