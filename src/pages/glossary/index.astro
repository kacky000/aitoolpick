---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import glossary from '../../data/glossary.json';

const sorted = [...glossary].sort((a, b) => a.term.localeCompare(b.term));

// Group by first letter
const grouped = new Map<string, typeof glossary>();
for (const entry of sorted) {
  const letter = entry.term.charAt(0).toUpperCase();
  if (!grouped.has(letter)) grouped.set(letter, []);
  grouped.get(letter)!.push(entry);
}
---

<BaseLayout
  title="Glossary — SaaS & AI Terminology Explained | AIToolPick"
  description={`${glossary.length} terms defined. Learn the meaning of SaaS, AI, and productivity tool terminology.`}
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Glossary' },
      ]} />

      <h1 style="margin-bottom: 0.5rem;">Glossary</h1>
      <p style="color: var(--gray-600); margin-bottom: 2rem;">
        {glossary.length} terms explained — from AI and SaaS to project management and development.
      </p>

      <div class="alpha-nav">
        {[...grouped.keys()].map((letter) => (
          <a href={`#letter-${letter}`} class="alpha-link">{letter}</a>
        ))}
      </div>

      {[...grouped.entries()].map(([letter, entries]) => (
        <div class="glossary-section" id={`letter-${letter}`}>
          <h2 class="glossary-letter">{letter}</h2>
          <div class="glossary-list">
            {entries.map((entry) => (
              <a href={`/glossary/${entry.slug}/`} class="glossary-item">
                <strong>{entry.term}</strong>
                <p>{entry.definition.slice(0, 100)}{entry.definition.length > 100 ? '...' : ''}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .alpha-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 2rem;
    position: sticky;
    top: 60px;
    background: var(--bg);
    padding: 0.75rem 0;
    z-index: 10;
  }

  .alpha-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: var(--gray-100);
    color: var(--gray-700);
    font-weight: 600;
    font-size: 0.82rem;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .alpha-link:hover {
    background: var(--primary);
    color: white;
  }

  .glossary-section {
    margin-bottom: 2.5rem;
  }

  .glossary-letter {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--primary-dark);
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--primary-light);
    margin-bottom: 1rem;
  }

  .glossary-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.75rem;
  }

  .glossary-item {
    display: block;
    padding: 1rem 1.25rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .glossary-item:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-sm);
  }

  .glossary-item strong {
    display: block;
    font-size: 0.95rem;
    color: var(--dark);
    margin-bottom: 0.3rem;
  }

  .glossary-item p {
    font-size: 0.82rem;
    color: var(--gray-600);
    line-height: 1.4;
    margin: 0;
  }
</style>
