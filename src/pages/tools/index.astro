---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import tools from '../../data/tools.json';
import categories from '../../data/categories.json';

const sortedTools = [...tools].sort((a, b) => a.name.localeCompare(b.name));

function formatPrice(pricing: Record<string, number | boolean | null>): string {
  const entries = Object.entries(pricing).filter(([key, val]) => key !== 'free' && val !== null && typeof val === 'number');
  if (entries.length === 0) return pricing.free ? 'Free' : 'Contact sales';
  const lowest = Math.min(...entries.map(([, v]) => v as number));
  return pricing.free ? `Free / $${lowest}+` : `$${lowest}+`;
}

const pageTitle = `All ${tools.length} Tools — Complete Software Directory | AIToolPick`;
const pageDescription = `Browse our complete directory of ${tools.length}+ AI and productivity tools. Filter by category, price, and rating to find your perfect match.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'All Tools' },
      ]} />

      <div class="page-header">
        <h1>All Tools ({tools.length})</h1>
        <p>Complete directory of AI and productivity tools, sorted alphabetically.</p>
      </div>

      <!-- Filters -->
      <div class="filters" id="filters">
        <div class="filter-group">
          <label>Category:</label>
          <select id="filter-category">
            <option value="">All Categories</option>
            {categories.filter(c => tools.some(t => t.category.includes(c.id))).map((cat) => (
              <option value={cat.id}>{cat.name}</option>
            ))}
          </select>
        </div>
        <div class="filter-group">
          <label>Price:</label>
          <select id="filter-price">
            <option value="">Any Price</option>
            <option value="free">Free Plan Available</option>
            <option value="paid">Paid Only</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Rating:</label>
          <select id="filter-rating">
            <option value="">Any Rating</option>
            <option value="4.5">4.5+ Stars</option>
            <option value="4.0">4.0+ Stars</option>
            <option value="3.5">3.5+ Stars</option>
          </select>
        </div>
        <div class="filter-group">
          <input type="text" id="filter-search" placeholder="Search by name..." class="filter-search" />
        </div>
      </div>

      <!-- Tools Grid -->
      <div class="tools-grid" id="tools-grid">
        {sortedTools.map((tool) => (
          <a href={`/tools/${tool.slug}/`} class="tool-list-card" data-categories={tool.category.join(',')} data-free={tool.pricing.free ? 'true' : 'false'} data-rating={tool.rating} data-name={tool.name.toLowerCase()}>
            <div class="tool-list-header">
              {tool.icon && <img src={tool.icon} alt={tool.name} width="36" height="36" class="tool-list-icon" loading="lazy" />}
              <div>
                <h2 class="tool-list-name">{tool.name}</h2>
                <span class="tool-list-rating">{'★'.repeat(Math.round(tool.rating))} {tool.rating}</span>
              </div>
              <span class="tool-list-price">{formatPrice(tool.pricing)}</span>
            </div>
            <p class="tool-list-desc">{tool.description}</p>
            <div class="tool-list-tags">
              {tool.category.slice(0, 2).map((catId: string) => {
                const cat = categories.find(c => c.id === catId);
                return cat ? <span class="card-tag">{cat.icon} {cat.name}</span> : null;
              })}
              {tool.pricing.free && <span class="card-tag free-tag">Free</span>}
            </div>
          </a>
        ))}
      </div>

      <p class="results-count" id="results-count">{tools.length} tools shown</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const grid = document.getElementById('tools-grid');
  const cards = grid.querySelectorAll('.tool-list-card');
  const countEl = document.getElementById('results-count');
  const catFilter = document.getElementById('filter-category');
  const priceFilter = document.getElementById('filter-price');
  const ratingFilter = document.getElementById('filter-rating');
  const searchFilter = document.getElementById('filter-search');

  function applyFilters() {
    const cat = catFilter.value;
    const price = priceFilter.value;
    const rating = parseFloat(ratingFilter.value) || 0;
    const search = searchFilter.value.toLowerCase().trim();
    let shown = 0;

    cards.forEach(card => {
      const categories = card.dataset.categories.split(',');
      const isFree = card.dataset.free === 'true';
      const cardRating = parseFloat(card.dataset.rating);
      const name = card.dataset.name;

      let visible = true;
      if (cat && !categories.includes(cat)) visible = false;
      if (price === 'free' && !isFree) visible = false;
      if (price === 'paid' && isFree) visible = false;
      if (rating && cardRating < rating) visible = false;
      if (search && !name.includes(search)) visible = false;

      card.style.display = visible ? '' : 'none';
      if (visible) shown++;
    });

    countEl.textContent = `${shown} tools shown`;
  }

  catFilter.addEventListener('change', applyFilters);
  priceFilter.addEventListener('change', applyFilters);
  ratingFilter.addEventListener('change', applyFilters);
  searchFilter.addEventListener('input', applyFilters);
</script>

<style>
  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.4rem;
  }

  .page-header p {
    color: var(--gray-600);
    font-size: 1rem;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray-200);
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .filter-group label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--gray-600);
  }

  .filter-group select,
  .filter-search {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--gray-300);
    border-radius: var(--radius);
    font-size: 0.88rem;
    background: var(--white);
    min-width: 160px;
  }

  .filter-search {
    min-width: 200px;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .tool-list-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.25rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  .tool-list-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  .tool-list-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tool-list-icon {
    border-radius: 8px;
    flex-shrink: 0;
  }

  .tool-list-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--dark);
    margin: 0;
  }

  .tool-list-rating {
    font-size: 0.78rem;
    color: var(--warning);
  }

  .tool-list-price {
    margin-left: auto;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary-dark);
    background: var(--primary-light);
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    white-space: nowrap;
  }

  .tool-list-desc {
    font-size: 0.84rem;
    color: var(--gray-600);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .tool-list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  .free-tag {
    background: var(--primary-light) !important;
    color: var(--primary-dark) !important;
  }

  .results-count {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--gray-500);
  }

  @media (max-width: 600px) {
    .filters {
      flex-direction: column;
    }

    .filter-group select,
    .filter-search {
      width: 100%;
      min-width: unset;
    }

    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
