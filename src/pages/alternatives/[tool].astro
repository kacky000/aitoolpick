---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';

export function getStaticPaths() {
  return tools.map((tool) => ({
    params: { tool: tool.slug },
    props: { currentTool: tool },
  }));
}

const { currentTool } = Astro.props;

// Find tools in the same categories
const alternatives = tools.filter(
  (t) =>
    t.id !== currentTool.id &&
    t.category.some((c) => currentTool.category.includes(c))
);

function formatPrice(pricing: Record<string, number | boolean | null>): string {
  const entries = Object.entries(pricing).filter(([key, val]) => key !== 'free' && val !== null && typeof val === 'number');
  if (entries.length === 0) return pricing.free ? 'Free' : 'Contact sales';
  const lowest = Math.min(...entries.map(([, v]) => v as number));
  return pricing.free ? `Free / $${lowest}+` : `$${lowest}+`;
}

const pageTitle = `Best ${currentTool.name} Alternatives in 2026`;
const pageDescription = `Looking for ${currentTool.name} alternatives? Compare ${alternatives.length} similar tools with features, pricing, and reviews.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="alternatives-header">
    {currentTool.icon && <img src={currentTool.icon} alt={`${currentTool.name} icon`} width="48" height="48" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 0.75rem;" />}
    <h1>Best {currentTool.name} Alternatives</h1>
    <p style="color: var(--gray-600); margin-top: 0.5rem; font-size: 1.1rem;">
      {alternatives.length} tools that can replace or complement {currentTool.name}
    </p>
  </div>

  <!-- Price Comparison Table -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <h2 style="margin-bottom: 1.5rem;">Pricing Comparison</h2>
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Tool</th>
            <th>Free Plan</th>
            <th>Starting Price</th>
            <th>Rating</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="feature-label">{currentTool.icon && <img src={currentTool.icon} alt="" width="20" height="20" class="th-icon" />} {currentTool.name}</td>
            <td class={currentTool.pricing.free ? 'check' : 'cross'}>{currentTool.pricing.free ? '✓ Yes' : '✗ No'}</td>
            <td>{formatPrice(currentTool.pricing)}</td>
            <td>★ {currentTool.rating}</td>
          </tr>
          {alternatives.map((alt) => (
            <tr>
              <td class="feature-label">
                {alt.icon && <img src={alt.icon} alt="" width="20" height="20" class="th-icon" />}
                <a href={`/alternatives/${alt.slug}/`}>{alt.name}</a>
              </td>
              <td class={alt.pricing.free ? 'check' : 'cross'}>{alt.pricing.free ? '✓ Yes' : '✗ No'}</td>
              <td>{formatPrice(alt.pricing)}</td>
              <td>★ {alt.rating}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Rich Alternatives Grid -->
  <section class="section section-alt">
    <div class="container">
      <h2 style="margin-bottom: 1.5rem;">All {currentTool.name} Alternatives</h2>
      <div class="rich-alt-grid">
        {alternatives.map((alt) => {
          const compareSlug = [currentTool.slug, alt.slug].sort().join('-vs-');
          return (
            <div class="rich-alt-card">
              <div class="rich-alt-header">
                <div class="rich-alt-identity">
                  {alt.icon && <img src={alt.icon} alt={`${alt.name} icon`} width="36" height="36" class="rich-alt-icon" />}
                  <div>
                    <h3 class="rich-alt-name">{alt.name}</h3>
                    <span class="rich-alt-rating">{'★'.repeat(Math.round(alt.rating))}{'☆'.repeat(5 - Math.round(alt.rating))} {alt.rating}</span>
                  </div>
                </div>
                <span class="rich-alt-price">{formatPrice(alt.pricing)}</span>
              </div>

              <p class="rich-alt-desc">{alt.description}</p>

              <div class="rich-alt-pros-cons">
                <ul class="rich-alt-pros">
                  {alt.pros.slice(0, 3).map((pro: string) => (
                    <li>
                      <span class="check-icon">✓</span> {pro}
                    </li>
                  ))}
                </ul>
                <ul class="rich-alt-cons">
                  {alt.cons.slice(0, 2).map((con: string) => (
                    <li>
                      <span class="cross-icon">✗</span> {con}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="rich-alt-footer">
                <a href={`/compare/${compareSlug}/`} class="btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem;">
                  Compare with {currentTool.name} &rarr;
                </a>
                <a href={`/alternatives/${alt.slug}/`} class="rich-alt-more">
                  See alternatives &rarr;
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Not Sure Which to Pick?</h2>
        <p>Compare {currentTool.name} against any alternative side-by-side.</p>
        {alternatives.length > 0 && (
          <a href={`/compare/${[currentTool.slug, alternatives[0].slug].sort().join('-vs-')}/`} class="btn-primary">
            Compare {currentTool.name} vs {alternatives[0].name} &rarr;
          </a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .rich-alt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .rich-alt-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .rich-alt-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .rich-alt-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .rich-alt-identity {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .rich-alt-icon {
    border-radius: 8px;
    flex-shrink: 0;
  }

  .rich-alt-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--dark);
    margin: 0 0 0.15rem;
  }

  .rich-alt-rating {
    font-size: 0.78rem;
    color: var(--warning);
    letter-spacing: 0.5px;
  }

  .rich-alt-price {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--primary-dark);
    background: var(--primary-light);
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .rich-alt-desc {
    font-size: 0.88rem;
    color: var(--gray-600);
    line-height: 1.55;
    margin: 0;
  }

  .rich-alt-pros-cons {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .rich-alt-pros,
  .rich-alt-cons {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .rich-alt-pros li,
  .rich-alt-cons li {
    font-size: 0.84rem;
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    line-height: 1.4;
    color: var(--gray-700);
  }

  .check-icon {
    color: var(--success);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .cross-icon {
    color: var(--danger);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .rich-alt-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .rich-alt-more {
    font-size: 0.83rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .rich-alt-more:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }
</style>
