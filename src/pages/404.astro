---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Page Not Found — AIToolPick";
const description = "The page you're looking for doesn't exist.";
---

<BaseLayout title={title} description={description}>
  <section class="container" style="text-align: center; padding: 4rem 1rem;">
    <h1 style="font-size: 3rem; margin-bottom: 0.5rem;">404</h1>
    <p style="font-size: 1.25rem; color: var(--text-muted, #666); margin-bottom: 2rem;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div style="display: flex; flex-direction: column; align-items: center; gap: 1rem;">
      <a href="/" class="btn-primary">Back to Home</a>
      <a href="/rankings/">Browse Tools</a>
      <a href="/blog/">Search our blog</a>
    </div>
  </section>
</BaseLayout>
