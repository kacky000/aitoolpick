---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import tools from '../../data/tools.json';

// Build audience map
const audienceMap = new Map<string, number>();
for (const tool of tools) {
  for (const bf of tool.bestFor) {
    audienceMap.set(bf, (audienceMap.get(bf) || 0) + 1);
  }
}

// Filter to audiences with 2+ tools and sort by count
const audiences = Array.from(audienceMap.entries())
  .filter(([, count]) => count >= 2)
  .sort((a, b) => b[1] - a[1]);

function formatAudience(slug: string): string {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase());
}

// Group audiences by first letter for quick navigation
const grouped = new Map<string, typeof audiences>();
for (const [aud, count] of audiences) {
  const letter = formatAudience(aud).charAt(0).toUpperCase();
  if (!grouped.has(letter)) grouped.set(letter, []);
  grouped.get(letter)!.push([aud, count]);
}

const pageTitle = 'Best Tools by Audience — Find Software for Your Role | AIToolPick';
const pageDescription = `Browse ${audiences.length} audience segments to find the best tools for your role, team size, and workflow needs.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Best For' },
      ]} />

      <div class="page-header">
        <h1>Best Tools by Audience</h1>
        <p>Find the perfect tools for your role. {audiences.length} audience segments, {tools.length}+ tools.</p>
      </div>

      <!-- Top audiences -->
      <div class="top-audiences">
        <h2>Most Popular</h2>
        <div class="top-grid">
          {audiences.slice(0, 20).map(([aud, count]) => (
            <a href={`/best-for/${aud}/`} class="top-card">
              <span class="top-name">{formatAudience(aud)}</span>
              <span class="top-count">{count} tools</span>
            </a>
          ))}
        </div>
      </div>

      <!-- All audiences alphabetical -->
      <div class="all-audiences">
        <h2>All Audiences (A–Z)</h2>
        <div class="alpha-nav">
          {[...grouped.keys()].sort().map((letter) => (
            <a href={`#letter-${letter}`} class="alpha-link">{letter}</a>
          ))}
        </div>

        {[...grouped.entries()].sort(([a], [b]) => a.localeCompare(b)).map(([letter, items]) => (
          <div class="alpha-section" id={`letter-${letter}`}>
            <h3 class="alpha-letter">{letter}</h3>
            <div class="alpha-grid">
              {items.map(([aud, count]) => (
                <a href={`/best-for/${aud}/`} class="audience-item">
                  <span>{formatAudience(aud)}</span>
                  <span class="audience-count">{count}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--gray-600);
    font-size: 1.05rem;
  }

  .top-audiences {
    margin-bottom: 3rem;
  }

  .top-audiences h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .top-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .top-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .top-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .top-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--dark);
  }

  .top-count {
    font-size: 0.75rem;
    color: var(--gray-500);
    background: var(--gray-100);
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
  }

  .all-audiences h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .alpha-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 2rem;
    position: sticky;
    top: 60px;
    background: var(--bg);
    padding: 0.75rem 0;
    z-index: 10;
  }

  .alpha-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: var(--gray-100);
    color: var(--gray-700);
    font-weight: 600;
    font-size: 0.82rem;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .alpha-link:hover {
    background: var(--primary);
    color: white;
  }

  .alpha-section {
    margin-bottom: 2rem;
  }

  .alpha-letter {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary-dark);
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--primary-light);
  }

  .alpha-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.5rem;
  }

  .audience-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--gray-700);
    font-size: 0.88rem;
    transition: background 0.12s;
  }

  .audience-item:hover {
    background: var(--gray-100);
    color: var(--primary-dark);
  }

  .audience-count {
    font-size: 0.72rem;
    font-weight: 600;
    background: var(--gray-100);
    color: var(--gray-500);
    padding: 0.15rem 0.4rem;
    border-radius: 10px;
    min-width: 20px;
    text-align: center;
  }
</style>
