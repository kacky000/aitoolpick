---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import tools from '../../data/tools.json';

export function getStaticPaths() {
  const paths = [];

  for (let i = 0; i < tools.length; i++) {
    for (let j = i + 1; j < tools.length; j++) {
      const toolA = tools[i];
      const toolB = tools[j];

      // toolA.id < toolB.id (alphabetical) for canonical URL
      const [first, second] = toolA.id < toolB.id ? [toolA, toolB] : [toolB, toolA];

      paths.push({
        params: { slug: `${first.slug}-vs-${second.slug}` },
        props: { toolA: first, toolB: second },
      });
    }
  }

  return paths;
}

const { toolA, toolB } = Astro.props;

// Find related comparisons (tools that share a category with either toolA or toolB)
const allCategories = [...new Set([...toolA.category, ...toolB.category])];
const relatedTools = tools.filter(
  (t) => t.id !== toolA.id && t.id !== toolB.id && t.category.some((c) => allCategories.includes(c))
).slice(0, 6);

const relatedComparisons = relatedTools.map((t) => {
  const [first, second] = toolA.id < t.id ? [toolA, t] : [t, toolA];
  return {
    slug: `${first.slug}-vs-${second.slug}`,
    label: `${first.name} vs ${second.name}`,
  };
});

const pageTitle = `${toolA.name} vs ${toolB.name}: Which Is Better in 2026?`;
const pageDescription = `Compare ${toolA.name} and ${toolB.name} side-by-side. See pricing, features, pros & cons to decide which tool is right for you.`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: `https://aitoolpick.vercel.app/compare/${toolA.slug}-vs-${toolB.slug}/`,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        item: {
          '@type': 'SoftwareApplication',
          name: toolA.name,
          url: toolA.website,
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: toolA.rating,
            bestRating: 5,
          },
        },
      },
      {
        '@type': 'ListItem',
        position: 2,
        item: {
          '@type': 'SoftwareApplication',
          name: toolB.name,
          url: toolB.website,
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: toolB.rating,
            bestRating: 5,
          },
        },
      },
    ],
  },
});
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={jsonLd} />

  <section class="section">
    <div class="container">
      <ComparisonTable toolA={toolA} toolB={toolB} />

      <!-- Verdict -->
      <div style="margin-top: 3rem; text-align: center;">
        <h2>The Verdict</h2>
        <p style="max-width: 700px; margin: 1rem auto; color: var(--gray-600); line-height: 1.8;">
          <strong>{toolA.name}</strong> is best for {toolA.bestFor.slice(0, 2).join(' and ')} who need {toolA.pros[0].toLowerCase()}.
          <strong>{toolB.name}</strong> is ideal for {toolB.bestFor.slice(0, 2).join(' and ')} looking for {toolB.pros[0].toLowerCase()}.
          Both tools offer {toolA.pricing.free && toolB.pricing.free ? 'free plans' : 'competitive pricing'}, so try each to see which fits your workflow.
        </p>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href={toolA.website} class="btn-primary" target="_blank" rel="noopener noreferrer">Try {toolA.name} &rarr;</a>
          <a href={toolB.website} class="btn-secondary" target="_blank" rel="noopener noreferrer">Try {toolB.name} &rarr;</a>
        </div>
      </div>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <div style="margin-top: 4rem;">
          <h2 class="section-title">Related Comparisons</h2>
          <div class="comparison-links" style="margin-top: 1.5rem;">
            {relatedComparisons.map((comp) => (
              <a href={`/compare/${comp.slug}/`} class="comparison-link">
                <span>{comp.label}</span>
                <span class="arrow">&rarr;</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
