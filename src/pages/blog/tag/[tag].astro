---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const tagMap = new Map<string, typeof allPosts>();

  for (const post of allPosts) {
    const tags = post.data.tags || [];
    for (const tag of tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }

  return Array.from(tagMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

function formatTag(t: string): string {
  return t.replace(/-/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase());
}

const formattedTag = formatTag(tag);
const pageTitle = `${formattedTag} — Articles & Guides | AIToolPick`;
const pageDescription = `${posts.length} articles about ${formattedTag.toLowerCase()}. Read guides, comparisons, and tips.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Blog', href: '/blog/' },
        { label: formattedTag },
      ]} />

      <div class="tag-header">
        <h1>Articles tagged "{formattedTag}"</h1>
        <p>{posts.length} {posts.length === 1 ? 'article' : 'articles'}</p>
      </div>

      <div class="post-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card" style="text-decoration: none; color: inherit;">
            {post.data.heroImage ? (
              <img class="post-card-image" src={post.data.heroImage} alt={post.data.title} loading="lazy" />
            ) : (
              <div class="post-card-image post-card-image--placeholder">
                <span>{post.data.title.slice(0, 1)}</span>
              </div>
            )}
            <div class="post-card-body">
              <p class="post-card-date">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-excerpt">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tag-header {
    margin-bottom: 2rem;
  }

  .tag-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 0.3rem;
  }

  .tag-header p {
    color: var(--gray-600);
    font-size: 0.95rem;
  }
</style>
