---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const perPage = 12;
  const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  const totalPages = Math.ceil(allPosts.length / perPage);
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: {
      posts: allPosts.slice((i + 1) * perPage, (i + 2) * perPage),
      currentPage: i + 2,
      totalPages,
    },
  }));
}

const { posts, currentPage, totalPages } = Astro.props;
---

<BaseLayout
  title={`Blog — Page ${currentPage} | AIToolPick`}
  description="Tips, guides, and insights on the best AI and productivity tools."
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">Blog</h1>
      <p class="section-subtitle">Guides, reviews, and insights on the best tools for your workflow.</p>

      <div class="post-grid">
        {posts.map((post: any) => (
          <a href={`/blog/${post.id}/`} class="post-card" style="text-decoration: none; color: inherit;">
            {post.data.heroImage ? (
              <img class="post-card-image" src={post.data.heroImage} alt={post.data.title} loading="lazy" />
            ) : (
              <div class="post-card-image post-card-image--placeholder">
                <span>{post.data.title.slice(0, 1)}</span>
              </div>
            )}
            <div class="post-card-body">
              <p class="post-card-date">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-excerpt">{post.data.description}</p>
              {post.data.tags && (
                <div class="post-card-tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="card-tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>

      <nav class="pagination" aria-label="Blog pagination">
        {currentPage > 1 && (
          <a href={currentPage === 2 ? '/blog/' : `/blog/${currentPage - 1}/`} class="pagination-prev">&larr; Prev</a>
        )}
        <a href="/blog/" class="pagination-link">1</a>
        {[...Array(totalPages - 1)].map((_, i) => i + 2).filter((num) =>
          Math.abs(num - currentPage) <= 2 || num === totalPages
        ).map((num) => (
          num === currentPage
            ? <span class="pagination-current">{num}</span>
            : <a href={`/blog/${num}/`} class="pagination-link">{num}</a>
        ))}
        {currentPage < totalPages && (
          <a href={`/blog/${currentPage + 1}/`} class="pagination-next">Next &rarr;</a>
        )}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }
  .pagination-current {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    background: var(--primary);
    color: #fff;
    font-weight: 600;
  }
  .pagination-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--gray-300);
    color: var(--gray-700);
    text-decoration: none;
    font-weight: 500;
  }
  .pagination-link:hover {
    background: var(--gray-100);
  }
  .pagination-prev, .pagination-next {
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--primary);
    color: var(--primary);
    text-decoration: none;
    font-weight: 500;
  }
  .pagination-prev:hover, .pagination-next:hover {
    background: var(--primary);
    color: #fff;
  }
  .pagination-ellipsis {
    color: var(--gray-400);
  }
  .post-card-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--primary), #6366f1);
    color: #fff;
    font-size: 2rem;
    font-weight: 700;
  }
</style>
