---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const POSTS_PER_PAGE = 12;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout
  title="Blog | AIToolPick"
  description="Tips, guides, and insights on the best AI and productivity tools. Learn how to optimize your workflow."
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">Blog</h1>
      <p class="section-subtitle">Guides, reviews, and insights on the best tools for your workflow.</p>

      <div class="post-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card" style="text-decoration: none; color: inherit;">
            {post.data.heroImage ? (
              <img class="post-card-image" src={post.data.heroImage} alt={post.data.title} loading="lazy" />
            ) : (
              <div class="post-card-image post-card-image--placeholder">
                <span>{post.data.title.slice(0, 1)}</span>
              </div>
            )}
            <div class="post-card-body">
              <p class="post-card-date">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-excerpt">{post.data.description}</p>
              {post.data.tags && (
                <div class="post-card-tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="card-tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Blog pagination">
          <span class="pagination-current">1</span>
          {Array.from({ length: Math.min(totalPages - 1, 4) }, (_, i) => i + 2).map((num) => (
            <a href={`/blog/${num}/`} class="pagination-link">{num}</a>
          ))}
          {totalPages > 5 && <span class="pagination-ellipsis">...</span>}
          {totalPages > 5 && (
            <a href={`/blog/${totalPages}/`} class="pagination-link">{totalPages}</a>
          )}
          <a href="/blog/2/" class="pagination-next">Next &rarr;</a>
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }
  .pagination-current {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.5rem;
    background: var(--primary);
    color: #fff;
    font-weight: 600;
  }
  .pagination-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--gray-300);
    color: var(--gray-700);
    text-decoration: none;
    font-weight: 500;
  }
  .pagination-link:hover {
    background: var(--gray-100);
  }
  .pagination-next {
    margin-left: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--primary);
    color: var(--primary);
    text-decoration: none;
    font-weight: 500;
  }
  .pagination-next:hover {
    background: var(--primary);
    color: #fff;
  }
  .pagination-ellipsis {
    color: var(--gray-400);
  }
  .post-card-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--primary), #6366f1);
    color: #fff;
    font-size: 2rem;
    font-weight: 700;
  }
</style>
