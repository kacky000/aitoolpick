---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog | AIToolPick"
  description="Tips, guides, and insights on the best AI and productivity tools. Learn how to optimize your workflow."
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">Blog</h1>
      <p class="section-subtitle">Guides, reviews, and insights on the best tools for your workflow.</p>

      <div class="post-grid">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card" style="text-decoration: none; color: inherit;">
            {post.data.heroImage ? (
              <img class="post-card-image" src={post.data.heroImage} alt={post.data.title} />
            ) : (
              <div class="post-card-image"></div>
            )}
            <div class="post-card-body">
              <p class="post-card-date">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-excerpt">{post.data.description}</p>
              {post.data.tags && (
                <div class="post-card-tags">
                  {post.data.tags.map((tag: string) => (
                    <span class="card-tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
